    "repository": "PhanAnh1001/child-knowledge-tree",
    "description": "Dự án sử dụng tiếng Việt, chứa kiến thức cơ bản cốt lõi về các khái niệm dưới dạng truyện tranh hài hước lầy lội.",
    "content_style": [
      "truyen-tranh",
      "hai-huoc",
      "lay-loi",
      "de-hieu",
      "ap-dung-thuc-te"
    ]
  },
  "paths": {
